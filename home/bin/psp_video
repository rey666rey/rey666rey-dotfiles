#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: psp_video [--overwrite | --skip-existing] <input_file|input_dir> <output_file|output_dir>

Options:
  --overwrite      Replace existing output files.
  --skip-existing  Skip existing output files (default).
  -h, --help       Show this help.
EOF
}

overwrite_mode="skip"
args=()

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --overwrite)
      overwrite_mode="overwrite"
      ;;
    --skip-existing)
      overwrite_mode="skip"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [[ "$#" -gt 0 ]]; do
        args+=("$1")
        shift
      done
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift
done

if [[ "${#args[@]}" -ne 2 ]]; then
  usage
  exit 1
fi

input_path="${args[0]}"
output_path="${args[1]}"

if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "Missing required command: ffmpeg" >&2
  exit 1
fi

if [[ ! -e "$input_path" ]]; then
  echo "Input path does not exist: $input_path" >&2
  exit 1
fi

shopt -s nullglob nocasematch

is_supported_video() {
  local path="$1"

  case "${path##*.}" in
    mp4|avi|mkv|mov|m4v)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

convert_video() {
  local input_file="$1"
  local output_file="$2"

  mkdir -p "$(dirname "$output_file")"

  if [[ -e "$output_file" ]]; then
    if [[ "$overwrite_mode" == "skip" ]]; then
      echo "Skipping existing file: $output_file"
      return 10
    fi

    echo "Overwriting existing file: $output_file"
  fi

  echo "Converting: $input_file"
  echo "Output: $output_file"

  ffmpeg -nostdin -hide_banner -loglevel warning -stats \
    -y \
    -i "$input_file" \
    -vf "scale=480:272:force_original_aspect_ratio=decrease,pad=480:272:(ow-iw)/2:(oh-ih)/2" \
    -c:v libx264 -profile:v baseline -level 3.0 -pix_fmt yuv420p \
    -preset medium -crf 23 \
    -x264-params "bframes=0:ref=1:cabac=0" \
    -c:a aac -b:a 128k -ar 44100 -ac 2 \
    -movflags +faststart \
    "$output_file"
}

if [[ -f "$input_path" ]]; then
  if ! is_supported_video "$input_path"; then
    echo "Unsupported input format: $input_path" >&2
    exit 1
  fi

  if [[ -d "$output_path" ]]; then
    output_file="$output_path/$(basename "${input_path%.*}").mp4"
  else
    output_file="$output_path"
  fi

  convert_video "$input_path" "$output_file"
  exit 0
fi

if [[ ! -d "$input_path" ]]; then
  echo "Input path is neither a file nor a directory: $input_path" >&2
  exit 1
fi

mkdir -p "$output_path"

found_files=0
converted_files=0
skipped_files=0

mapfile -d '' -t input_files < <(find "$input_path" -type f -print0 | sort -z)

for input_file in "${input_files[@]}"; do
  if ! is_supported_video "$input_file"; then
    continue
  fi

  found_files=1
  relative_path="${input_file#"$input_path"/}"
  output_file="$output_path/${relative_path%.*}.mp4"

  if convert_video "$input_file" "$output_file"; then
    ((converted_files+=1))
  else
    status=$?
    if [[ "$status" -eq 10 ]]; then
      ((skipped_files+=1))
    else
      exit "$status"
    fi
  fi
done

if [[ "$found_files" -eq 0 ]]; then
  echo "No supported video files found in: $input_path" >&2
  exit 1
fi

echo "Done. Converted: $converted_files, skipped: $skipped_files"
